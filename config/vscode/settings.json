{
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
    "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",

    "git.blame.statusBarItem.enabled": true,

    // Don't show "x" icon on tabs
    "workbench.editor.tabActionCloseVisibility": false,

    // Vertical activity bar is necessary to move between panes with vim keybinds.
    // https://github.com/getcursor/cursor/issues/1570
    "workbench.activityBar.orientation": "vertical",
    // Hide activity bar entirely (explorer, search, agents, extensions)
    "workbench.activityBar.location": "hidden",

    // Disable VSCode native popovers (opens in new tab with nvim)
    "editor.hover.enabled": "off",
    "editor.parameterHints.enabled": false,

    "editor.renderValidationDecorations": "off",
    "problems.decorations.enabled": false,

    "editor.minimap.enabled": false,
    "editor.inlineSuggest.enabled": false,

    // Do not insert final newline
    "files.insertFinalNewline": false,
    "workbench.colorTheme": "Tokyo Night Storm",
    "claudeCode.preferredLocation": "panel",

    // Play sound when Claude Code / Copilot chat finishes responding
    "accessibility.signals.chatResponseReceived": {
        "sound": "on"
    }
}
